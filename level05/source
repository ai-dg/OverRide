#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/*
 * Vulnerability:
 * Format string: printf(buf) treats user input as a format string after
 * lowercasing A-Z (XOR 0x20). Attackers use %x/%n to read/write memory.
 * exit(0) after printf prevents return to a corrupted frame; overwriting
 * exit@GOT with a shellcode address is the typical exploit path.
 */

int main(void)
{
	char buf[100];
	size_t i;
	size_t len;

	fgets(buf, sizeof(buf), stdin);
	len = strlen(buf);
	if (len > 0)
		len--;
	for (i = 0; i < len; i++) {
		if (buf[i] > '@' && buf[i] <= 'Z')
			buf[i] ^= 0x20; /* convert uppercase to lowercase */
	}
	printf(buf); /* FORMAT STRING VULNERABILITY */
	exit(0);
}
