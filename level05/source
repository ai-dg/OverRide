#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/*
 * Vulnerability (English):
 * - Format string: printf(buf) treats user input as a format string after optional case
 *   folding of 'A'..'Z'. Attackers can use % specifiers to read stack/GOT or write via %n.
 * - exit(0) after printf prevents returning into a corrupted stack frame; overwriting GOT
 *   entries for functions called before exit is a typical goal.
 */

int main(void)
{
	char buf[100];
	size_t i;
	size_t lim;

	fgets(buf, sizeof(buf), stdin);
	/* strlen puis -1 : boucle sur indices 0 .. len-2 (voir disassembly) */
	lim = strlen(buf);
	if (lim > 0)
		lim--;
	for (i = 0; i < lim; i++) {
		if (buf[i] > '@' && buf[i] <= 'Z')
			buf[i] ^= 0x20;
	}
	printf(buf); /* format string */
	exit(0);
}
