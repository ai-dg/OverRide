#include <stdio.h>
#include <string.h>

/*
 * Vulnerability / weakness (English):
 * - Plaintext credentials in .rodata: username prefix ("dat_wil") and password ("admin")
 *   are compared with memcmp against fixed strings in the binary — recoverable with
 *   strings(1) / objdump, no hashing.
 * - No buffer overflow in the reconstructed logic: fgets bounds match the buffers.
 *   The security failure is static, guessable authentication material in the executable.
 */

char a_user_name[256];

/*
 * Compare 7 octets du buffer global à la chaîne en .rodata ("dat_wil").
 * Même schéma que verify_user_pass : valeur de retour style strcmp.
 */
int verify_user_name(void)
{
	puts("verifying username....");
	return memcmp(a_user_name, "dat_wil", 7); /* static credential (binary leak) */
}

int verify_user_pass(char *pass)
{
	return memcmp(pass, "admin", 5); /* static credential (binary leak) */
}

int main(void)
{
	int r;
	char pass[100];

	memset(pass, 0, sizeof(pass));
	r = 0;

	puts("********* ADMIN LOGIN PROMPT *********");
	printf("Enter Username: ");
	fgets(a_user_name, 0x100, stdin);
	if (verify_user_name() != 0) {
		puts("nope, incorrect username...\n");
		return 1;
	}
	puts("Enter Password: ");
	fgets(pass, 0x64, stdin);
	r = verify_user_pass(pass);
	if (r != 0) {
		puts("nope, incorrect password...\n");
		return 1;
	}
	return 0;
}
