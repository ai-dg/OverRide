#include <stdio.h>
#include <stdlib.h>

/*
 * Vulnerability:
 * Hardcoded secret: the program compares user input to a fixed constant (0x149c = 5276)
 * embedded in the binary. Anyone who reads the disassembly can authenticate.
 * No memory corruption; the issue is a trivially recoverable credential (logic flaw).
 */

int main(void)
{
	int password;

	puts("***********************************");
	puts("* \t     -Level00 -\t\t  *");
	puts("***********************************");
	printf("Password:");
	scanf("%d", &password);
	if (password != 0x149c) {
		puts("\nInvalid Password!");
		return 1;
	}
	puts("\nAuthenticated!");
	system("/bin/sh");
	return 0;
}
