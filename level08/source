#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <fcntl.h>

/*
 * Vulnerability:
 * Path traversal via symlink abuse. The setuid binary reads argv[1] with elevated
 * privileges (fopen) and copies its content to ./backups/<argv[1]>. A direct path
 * like /home/users/level09/.pass fails because the nested directories don't exist
 * under ./backups/. A symlink with a simple name (e.g. "token") pointing to the
 * target file bypasses this: fopen follows the symlink with setuid rights, and the
 * backup path ./backups/token is a flat file that can be created and read.
 *
 * The strcpy in log_wrapper is technically an overflow, but the stack canary
 * (%fs:0x28) prevents exploitation via that path.
 */

void log_wrapper(FILE *log, char *msg, char *path)
{
	char buf[256];

	strcpy(buf, msg);
	snprintf(buf + strlen(buf), sizeof(buf) - strlen(buf) - 1, "%s", path);
	buf[strcspn(buf, "\n")] = '\0';
	fprintf(log, "LOG: %s\n", buf);
}

int main(int argc, char **argv)
{
	FILE *logf;
	FILE *in;
	int fd;
	char c;
	char outpath[100];

	if (argc != 2)
		printf("Usage: %s filename\n", argv[0]);
	logf = fopen("./backups/.log", "w");
	if (logf == NULL) {
		printf("ERROR: Failed to open %s\n", "./backups/.log");
		exit(1);
	}
	log_wrapper(logf, "Starting back up: ", argv[1]);
	in = fopen(argv[1], "r");
	if (in == NULL) {
		printf("ERROR: Failed to open %s\n", argv[1]);
		exit(1);
	}
	strcpy(outpath, "./backups/");
	strncat(outpath, argv[1], sizeof(outpath) - strlen(outpath) - 1);
	fd = open(outpath, O_CREAT | O_WRONLY | O_TRUNC, 0660);
	if (fd < 0) {
		printf("ERROR: Failed to open %s%s\n", "./backups/", argv[1]);
		exit(1);
	}
	while ((c = (char)fgetc(in)) != (char)EOF)
		write(fd, &c, 1);
	log_wrapper(logf, "Finished back up ", argv[1]);
	fclose(in);
	close(fd);
	return 0;
}
