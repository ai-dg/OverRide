#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <fcntl.h>

/*
 * Vulnerability (English):
 * - Stack buffer overflow in log_wrapper: strcpy(buf, prefix) copies prefix into a 256-byte
 *   stack buffer with no length check. A long first argument (e.g. attacker-controlled log
 *   tag built from argv) overflows buf — saved RIP / stack canaries may be corrupted.
 * - Path handling: strncat into outpath can still enable confusing paths; main design
 *   backs up into ./backups/ — combine with overflow for full exploit chain as per walkthrough.
 */

void log_wrapper(FILE *log, char *prefix, char *path)
{
	char buf[256];

	strcpy(buf, prefix); /* stack buffer overflow */
	strncat(buf, path, sizeof(buf) - strlen(buf) - 1);
	buf[strcspn(buf, "\n")] = '\0';
	fprintf(log, "LOG: %s\n", buf);
}

int main(int argc, char **argv)
{
	FILE *logf;
	FILE *in;
	int fd;
	char c;
	char outpath[128];

	/* Comme dans le binaire : affiche l’usage si argc != 2 puis continue */
	if (argc != 2)
		printf("Usage: %s filename\n", argv[0]);
	logf = fopen("./backups/.log", "w");
	if (logf == NULL) {
		printf("ERROR: Failed to open %s\n", "./backups/.log");
		exit(1);
	}
	log_wrapper(logf, "Starting back up: ", argv[1]);
	in = fopen(argv[1], "r");
	if (in == NULL) {
		printf("ERROR: Failed to open %s\n", argv[1]);
		exit(1);
	}
	strcpy(outpath, "./backups/");
	strncat(outpath, argv[1], sizeof(outpath) - strlen(outpath) - 1);
	fd = open(outpath, O_CREAT | O_WRONLY | O_TRUNC, 0660);
	if (fd < 0) {
		printf("ERROR: Failed to open %s%s\n", "./backups/", argv[1]);
		exit(1);
	}
	while ((c = (char)fgetc(in)) != (char)EOF)
		write(fd, &c, 1);
	log_wrapper(logf, "Finished back up ", argv[1]);
	fclose(in);
	close(fd);
	return 0;
}
