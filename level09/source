#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/*
 * Vulnerability:
 * Off-by-one in set_username: the loop copies with i <= 0x28 (41 iterations),
 * but username[] only holds 40 bytes. The 41st byte overwrites the LSB of
 * msg_max at offset +0xb4, corrupting the length used by strncpy in set_msg.
 * With msg_max set to 0xff (255), strncpy copies far past the msg buffer,
 * overwriting saved RBP and saved RIP on the stack.
 *
 * Hidden function: secret_backdoor() reads a command via fgets and passes it
 * to system(). Redirecting RIP to secret_backdoor gives a shell.
 */

typedef struct {
	char msg[0x8c];       /* offset 0x00 - 0x8b */
	char username[40];    /* offset 0x8c - 0xb3 */
	int msg_max;          /* offset 0xb4        */
} t_msg;

void secret_backdoor(void)
{
	char buf[128];

	fgets(buf, sizeof(buf), stdin);
	system(buf);
}

void set_username(t_msg *m)
{
	char line[128];
	int i;

	memset(line, 0, sizeof(line));
	puts(">: Enter your username");
	printf(">>: ");
	fgets(line, sizeof(line), stdin);
	for (i = 0; i <= 0x28 && line[i]; i++) /* off-by-one: writes 41 bytes */
		m->username[i] = line[i];
	printf(">: Welcome, %s", m->username);
}

void set_msg(t_msg *m)
{
	char line[1024];

	memset(line, 0, sizeof(line));
	puts(">: Msg @Unix-Dude");
	printf(">>: ");
	fgets(line, sizeof(line), stdin);
	strncpy(m->msg, line, (size_t)m->msg_max); /* overflow if msg_max corrupted */
}

void handle_msg(void)
{
	t_msg m;

	memset(&m, 0, sizeof(m));
	m.msg_max = 0x8c;
	set_username(&m);
	set_msg(&m);
	puts(">: Msg sent!");
}

int main(void)
{
	puts(
	    "--------------------------------------------\n"
	    "|   ~Welcome to l33t-m$n ~    v1337        |\n"
	    "--------------------------------------------");
	handle_msg();
	return 0;
}
