#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/wait.h>
#include <sys/ptrace.h>
#include <sys/prctl.h>
#include <signal.h>

/* Le binaire utilise gets() (non borné) — non déclaré en C11 strict */
extern char *gets(char *s);

/*
 * Vulnerability (English):
 * - Stack buffer overflow: gets(buf) reads unlimited input into a 128-byte stack buffer.
 *   There is no bounds checking — EIP/saved state can be overwritten (ret2libc, ROP, etc.).
 * - The parent process uses ptrace to block execve (syscall 11); shellcode that execs
 *   a shell is killed — exploit design must work around that (e.g. return-oriented code).
 */

int main(void)
{
	pid_t pid;
	int status;
	char buf[128];
	long orig_eax;

	memset(buf, 0, sizeof(buf));
	pid = fork();
	if (pid == 0) {
		prctl(PR_SET_PDEATHSIG, SIGHUP);
		ptrace(PTRACE_TRACEME, 0, NULL, NULL);
		puts("Give me some shellcode, k");
		gets(buf); /* stack buffer overflow */
	} else {
		while (1) {
			wait(&status);
			if (WIFEXITED(status)) {
				puts("child is exiting...");
				return 0;
			}
			/* PTRACE_PEEKUSER, orig_eax (i386) = 0x2c */
			orig_eax = ptrace(PTRACE_PEEKUSER, pid, 0x2c, NULL);
			if (orig_eax == 0xb)
				break;
		}
		puts("no exec() for you");
		kill(pid, SIGKILL);
	}
	return 0;
}
