#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

/*
 * Vulnerability:
 * No memory corruption. Security relies on reversing the decrypt() XOR cipher.
 * The encrypted buffer and the expected plaintext ("Congratulations!") are both
 * in the binary. XOR key = encrypted[0] ^ expected[0] = 0x51 ^ 0x43 = 18.
 * Since key = 0x1337d00d - input, the password is 0x1337d00d - 18 = 322424827.
 */

void decrypt(int key)
{
	char buf[] = {
		0x51, 0x7d, 0x7c, 0x75,
		0x60, 0x73, 0x66, 0x67,
		0x7e, 0x73, 0x66, 0x7b,
		0x7d, 0x7c, 0x61, 0x33,
		0x00
	};
	size_t len;
	size_t i;

	len = strlen(buf);
	for (i = 0; i < len; i++)
		buf[i] ^= key;
	if (strncmp(buf, "Congratulations!", 17) == 0)
		system("/bin/sh");
	else
		puts("Nope");
}

void test(unsigned int a, unsigned int b)
{
	unsigned int d;

	d = b - a;
	if (d > 21) {
		decrypt(rand());
		return;
	}
	/* Jump table: all 22 cases (0..21) call decrypt(d) */
	switch ((int)d) {
	case 0:  case 1:  case 2:  case 3:
	case 4:  case 5:  case 6:  case 7:
	case 8:  case 9:  case 10: case 11:
	case 12: case 13: case 14: case 15:
	case 16: case 17: case 18: case 19:
	case 20: case 21:
		decrypt(d);
		break;
	default:
		decrypt(rand());
		break;
	}
}

int main(void)
{
	unsigned int input;

	srand((unsigned)time(NULL));
	puts("***********************************");
	puts("*\t\tlevel03\t\t**");
	puts("***********************************");
	printf("Password:");
	scanf("%u", &input);
	test(input, 0x1337d00d);
	return 0;
}
