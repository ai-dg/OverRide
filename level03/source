#include <stdio.h>
#include <stdlib.h>
#include <time.h>

/*
 * Vulnerability / attack surface (English):
 * - No stack overflow in main; security depends on reverse-engineering decrypt() and
 *   choosing input so d = 0x1337d00d - input is in 0..0x15 (fixed switch cases), or
 *   dealing with decrypt(rand()) when d > 0x15 (srand(time(NULL)) makes that branch
 *   time-dependent).
 * - Unsigned subtraction d = b - a wraps if a > b; then d is huge, so the random branch
 *   is taken — unintended control flow, harder deterministic exploit without the right input.
 */

void decrypt(int x); /* définition dans le binaire */

/*
 * test(b - a) : saut via table (0..0x15) vers decrypt(x),
 * sinon decrypt(rand()).
 */
void test(unsigned int a, unsigned int b)
{
	unsigned int d;
	int idx;

	d = b - a; /* unsigned integer wrap if a > b → unintended branch */
	if (d > 0x15) {
		decrypt(rand()); /* weak path: time-seeded PRNG */
		return;
	}
	idx = (int)d;
	switch (idx) {
	case 0:  decrypt(idx); break;
	case 1:  decrypt(idx); break;
	case 2:  decrypt(idx); break;
	case 3:  decrypt(idx); break;
	case 4:  decrypt(idx); break;
	case 5:  decrypt(idx); break;
	case 6:  decrypt(idx); break;
	case 7:  decrypt(idx); break;
	case 8:  decrypt(idx); break;
	case 9:  decrypt(idx); break;
	case 10: decrypt(idx); break;
	case 11: decrypt(idx); break;
	case 12: decrypt(idx); break;
	case 13: decrypt(idx); break;
	case 14: decrypt(idx); break;
	case 15: decrypt(idx); break;
	case 16: decrypt(idx); break;
	case 17: decrypt(idx); break;
	case 18: decrypt(idx); break;
	case 19: decrypt(idx); break;
	case 20: decrypt(idx); break;
	case 21: decrypt(idx); break;
	default:
		decrypt(rand());
		break;
	}
}

int main(void)
{
	unsigned int input;

	srand((unsigned)time(NULL));
	puts("***********************************");
	puts("*\t\tlevel03\t\t**");
	puts("***********************************");
	printf("Password:");
	scanf("%u", &input);
	test(input, 0x1337d00d); /* logic / crypto: d = 0x1337d00d − input selects decrypt */
	return 0;
}
