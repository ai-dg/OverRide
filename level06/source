#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>
#include <unistd.h>
#include <sys/ptrace.h>

/*
 * Vulnerability:
 * Authentication bypass by serial forgery. The serial is accepted if it equals
 * a deterministic hash of the login string. An attacker who reimplements the
 * algorithm offline can compute a valid serial without any leak.
 * The ptrace(PTRACE_TRACEME) anti-debug check is a hurdle, not a real fix.
 */

unsigned int auth(char *login, unsigned int serial)
{
	size_t len;
	uint32_t hash;
	size_t i;
	int32_t ch;
	uint32_t xored;
	uint64_t prod;
	uint32_t hi;
	uint32_t tmp;

	login[strcspn(login, "\n")] = '\0';
	len = strnlen(login, 0x20);
	if (len <= 5)
		return 1;
	if (ptrace(PTRACE_TRACEME, 0, NULL, NULL) == -1) {
		puts("\x1b[32m.---------------------------.");
		puts("\x1b[31m| !! TAMPERING DETECTED !!  |");
		puts("\x1b[32m'--------------------------'");
		return 1;
	}
	hash = ((unsigned char)login[3] ^ 0x1337u) + 0x5eeded;
	for (i = 0; i < len; i++) {
		ch = (signed char)login[i];
		if (ch <= 0x1f)
			return 1;
		xored = (uint32_t)ch ^ hash;
		prod = (uint64_t)xored * 0x88233b2bULL;
		hi = (uint32_t)(prod >> 32);
		tmp = xored - hi;
		tmp = (tmp >> 1) + hi;
		tmp >>= 10;
		tmp *= 0x539;
		hash += xored - tmp;
	}
	return serial != hash;
}

int main(void)
{
	char login[32];
	unsigned int serial;

	puts("***********************************");
	puts("*\t\tlevel06\t\t  *");
	puts("***********************************");
	printf("-> Enter Login: ");
	fgets(login, sizeof(login), stdin);
	puts("***********************************");
	puts("***** NEW ACCOUNT DETECTED ********");
	puts("***********************************");
	printf("-> Enter Serial: ");
	scanf("%u", &serial);
	if (auth(login, serial) == 0) {
		puts("Authenticated!");
		system("/bin/sh");
	}
	return 0;
}
